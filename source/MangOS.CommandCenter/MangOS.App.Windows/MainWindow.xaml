<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MangOS.App.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MangOS.App.Windows">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="32">
        <StackPanel Spacing="24">
            <StackPanel Spacing="8">
                <!--Titulo Principal-->
                <TextBlock
                    Text="MangOS Command Center"
                    FontSize="32"
                    FontWeight="SemiBold"/>
                <!--Subtitulo-->
                <TextBlock 
                    Text="Centro de mando personal"
                    FontSize="16"
                    Opacity="0.7"/>
            </StackPanel>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox
                    x:Name="CaptureTextBox"
                    Grid.Column="0"
                    PlaceholderText="Escribe una idea, tarea, pregunta o avance..."
                    FontSize="16"
                    KeyDown="CaptureTextBox_KeyDown"/>
                <Button
                    Grid.Column="1"
                    Content="Enviar"
                    Click="CaptureButton_Click"/>
        </Grid> 
        </StackPanel>
    </Grid>
</Window>
